<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-menu-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
<link
  rel="stylesheet"
  href="{{ 'component-cart-notification.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>

{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

{%- if section.settings.menu_type_desktop == 'mega' -%}
  <link rel="stylesheet" href="{{ 'component-mega-menu.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

{%- comment -%} ===== PREMIUM HEADER ENHANCEMENTS (Phase 1 Foundation) ===== {%- endcomment -%}
{%- if section.settings.hp_enable_premium -%}
  <link rel="stylesheet" href="{{ 'header-premium.css' | asset_url }}" media="print" onload="this.media='all'">
  <script src="{{ 'header-premium.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<style>
  header-drawer {
    justify-self: start;
    margin-left: -1.2rem;
  }

  {%- if section.settings.sticky_header_type == 'reduce-logo-size' -%}
    .scrolled-past-header .header__heading-logo-wrapper {
      width: 75%;
    }
  {%- endif -%}

  {%- if section.settings.menu_type_desktop != "drawer" -%}
    @media screen and (min-width: 990px) {
      header-drawer {
        display: none;
      }
    }
  {%- endif -%}

  .menu-drawer-container {
    display: flex;
  }

  .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list-menu--inline {
    display: inline-flex;
    flex-wrap: wrap;
  }

  summary.list-menu__item {
    padding-right: 2.7rem;
  }

  .list-menu__item {
    display: flex;
    align-items: center;
    line-height: calc(1 + 0.3 / var(--font-body-scale));
  }

  .list-menu__item--link {
    text-decoration: none;
    padding-bottom: 1rem;
    padding-top: 1rem;
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  @media screen and (min-width: 750px) {
    .list-menu__item--link {
      padding-bottom: 0.5rem;
      padding-top: 0.5rem;
    }
  }
</style>

{%- style -%}
  .header {
    padding: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px 3rem {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px 3rem;
  }

  .section-header {
    position: sticky; /* This is for fixing a Safari z-index issue. PR #2147 */
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-header {
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .header {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  {%- comment -%} ===== PREMIUM HEADER CSS VARIABLES (Phases 1-3) ===== {%- endcomment -%}
  {%- if section.settings.hp_enable_premium -%}
    .section-header {
      --hp-top-line-height: {{ section.settings.hp_top_line_height }}px;
      --hp-top-line-color: {{ section.settings.hp_top_line_color }};

      /* Phase 2: Header layout & sizing */
      --hp-header-max-width: {{ section.settings.hp_header_max_width }}px;
      --hp-logo-padding: {{ section.settings.hp_logo_padding }}px;

      /* Phase 2: Transparent header colors */
      --hp-transparent-text: {{ section.settings.hp_transparent_text_color }};
      --hp-transparent-icon: {{ section.settings.hp_transparent_icon_color }};

      /* Phase 3: Navigation typography */
      --hp-menu-font-size: {{ section.settings.hp_menu_font_size }}px;
      --hp-menu-font-weight: {{ section.settings.hp_menu_font_weight }};
      --hp-menu-letter-spacing: {{ section.settings.hp_menu_letter_spacing }}px;

      /* Phase 3: Animation */
      --hp-anim-duration: {{ section.settings.hp_anim_duration }}ms;

      /* Phase 3: Hover effect */
      --hp-hover-underline-color: {{ section.settings.hp_hover_underline_color }};
      --hp-hover-underline-thickness: {{ section.settings.hp_hover_underline_thickness }}px;

      /* Phase 4: Icons & Actions */
      --hp-icon-size: {{ section.settings.hp_icon_size }}px;
      --hp-icon-spacing: {{ section.settings.hp_icon_spacing }}px;
      {%- if section.settings.hp_cart_badge_override -%}
      --hp-cart-badge-bg: {{ section.settings.hp_cart_badge_bg }};
      --hp-cart-badge-text: {{ section.settings.hp_cart_badge_text }};
      {%- endif -%}
      --hp-icon-hover-color: {{ section.settings.hp_icon_hover_color }};

      /* Phase 5: Mobile & Polish */
      --hp-mobile-bottom-nav-bg: {{ section.settings.hp_mobile_bottom_nav_bg }};
      --hp-mobile-bottom-nav-border: {{ section.settings.hp_mobile_bottom_nav_border }};
      --hp-mobile-menu-font-size: {{ section.settings.hp_mobile_menu_font_size }}px;
      --hp-mobile-menu-padding: {{ section.settings.hp_mobile_menu_padding }}px;

      /* Header Layout & Structure */
      --hp-header-height-desktop: {{ section.settings.hp_header_height_desktop }}px;
      --hp-header-height-mobile: {{ section.settings.hp_header_height_mobile }}px;
      --hp-header-bg-opacity: {{ section.settings.hp_header_bg_opacity | divided_by: 100.0 }};
      --hp-border-top-color: {{ section.settings.hp_border_top_color }};
      --hp-border-top-width: {{ section.settings.hp_border_top_width }}px;
      --hp-scroll-shrink: {{ section.settings.hp_scroll_shrink | divided_by: 100.0 }};
      --hp-scroll-bg-color: {{ section.settings.hp_scroll_bg_color }};
      --hp-nav-alignment: {{ section.settings.hp_nav_alignment }};
    }
  {%- endif -%}
{%- endstyle -%}

{%- if settings.cart_type == 'notification' -%}
  <script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- liquid
  for block in section.blocks
    if block.type == '@app'
      assign has_app_block = true
    endif
  endfor
-%}

{% liquid
  assign header_tag = 'div'

  if section.settings.sticky_header_type != 'none'
    assign header_tag = 'sticky-header'
  endif

  comment
    ===== PHASE 2: Transparent header detection =====
    Determine whether transparent header should be active on this page.
  endcomment
  assign hp_transparent_active = false
  if section.settings.hp_enable_premium and section.settings.hp_enable_transparent
    case section.settings.hp_transparent_apply_on
      when 'index'
        if request.page_type == 'index'
          assign hp_transparent_active = true
        endif
      when 'index_collection'
        if request.page_type == 'index' or request.page_type == 'collection'
          assign hp_transparent_active = true
        endif
      when 'all'
        assign hp_transparent_active = true
    endcase
  endif
%}

<{{ header_tag }}
  {% if header_tag == 'sticky-header' %}
    data-sticky-type="{{ section.settings.sticky_header_type }}"
  {% endif %}
  {% if hp_transparent_active %}
    data-hp-transparent="true"
    data-hp-transparent-border="{{ section.settings.hp_transparent_show_border }}"
  {% endif %}
  {%- if section.settings.hp_enable_premium -%}
    data-hp-trigger="{{ section.settings.hp_dropdown_trigger }}"
    data-hp-anim="{{ section.settings.hp_anim_type }}"
    data-hp-text-transform="{{ section.settings.hp_menu_text_transform }}"
    data-hp-hover-style="{{ section.settings.hp_hover_style }}"
    data-hp-cart-badge="{{ section.settings.hp_cart_badge_style }}"
    data-hp-cart-badge-pos="{{ section.settings.hp_cart_badge_position }}"
    data-hp-cart-badge-override="{{ section.settings.hp_cart_badge_override }}"
    data-hp-mobile-drawer="{{ section.settings.hp_mobile_drawer_position }}"
    data-hp-mobile-anim="{{ section.settings.hp_mobile_menu_anim }}"
    data-hp-mobile-text-transform="{{ section.settings.hp_mobile_menu_text_transform }}"
    data-hp-smooth-scroll="{{ section.settings.hp_smooth_scroll }}"
    data-hp-reduced-motion="{{ section.settings.hp_respect_reduced_motion }}"
    data-hp-vertical-align="{{ section.settings.hp_header_vertical_align }}"
    data-hp-shadow="{{ section.settings.hp_header_shadow }}"
    {% if section.settings.hp_header_bg_opacity < 100 %}data-hp-bg-opacity="{{ section.settings.hp_header_bg_opacity }}"{% endif %}
    data-hp-border-top="{{ section.settings.hp_border_top_show }}"
    {% if section.settings.hp_scroll_shrink > 0 %}data-hp-scroll-shrink="{{ section.settings.hp_scroll_shrink }}"{% endif %}
    data-hp-scroll-bg="{{ section.settings.hp_scroll_bg_change }}"
    data-hp-scroll-shadow="{{ section.settings.hp_scroll_shadow }}"
    data-hp-nav-align="{{ section.settings.hp_nav_alignment }}"
    data-hp-icon-align="{{ section.settings.hp_icon_alignment }}"
  {%- endif -%}
  class="header-wrapper color-{{ section.settings.color_scheme }} gradient{% if section.settings.show_line_separator %} header-wrapper--border-bottom{% endif %}{% if section.settings.hp_enable_premium %} header-wrapper--premium header-wrapper--layout-{{ section.settings.hp_header_layout }}{% endif %}{% if hp_transparent_active %} header-wrapper--transparent{% endif %}{% if section.settings.hp_enable_premium and section.settings.hp_header_width == 'boxed' %} header-wrapper--boxed{% endif %}"
>
  {%- comment -%} ===== PREMIUM TOP LINE (Phase 1: Jacket Maker style thin line) ===== {%- endcomment -%}
  {%- if section.settings.hp_enable_premium and section.settings.hp_show_top_line -%}
    <div class="hp-top-line" aria-hidden="true"></div>
  {%- endif -%}

  {%- liquid
    assign social_links = false
    assign localization_forms = false

    if settings.social_twitter_link != blank or settings.social_facebook_link != blank or settings.social_pinterest_link != blank or settings.social_instagram_link != blank or settings.social_youtube_link != blank or settings.social_vimeo_link != blank or settings.social_tiktok_link != blank or settings.social_tumblr_link != blank or settings.social_snapchat_link != blank
      assign social_links = true
    endif

    if localization.available_countries.size > 1 and section.settings.enable_country_selector or section.settings.enable_language_selector and localization.available_languages.size > 1
      assign localization_forms = true
    endif
  -%}
  <header class="header header--{{ section.settings.logo_position }} header--mobile-{{ section.settings.mobile_logo_position }} page-width{% if section.settings.menu_type_desktop == 'drawer' %} drawer-menu{% endif %}{% if section.settings.menu != blank %} header--has-menu{% endif %}{% if has_app_block %} header--has-app{% endif %}{% if social_links %} header--has-social{% endif %}{% if shop.customer_accounts_enabled %} header--has-account{% endif %}{% if localization_forms %} header--has-localizations{% endif %}">
    {%- liquid
      if section.settings.menu != blank
        render 'header-drawer'
      endif

      if section.settings.logo_position == 'top-center' or section.settings.menu == blank
        render 'header-search', input_id: 'Search-In-Modal-1'
      endif
    -%}

    {%- if section.settings.logo_position != 'middle-center' -%}
      {%- if request.page_type == 'index' -%}
        <h1 class="header__heading">
      {%- endif -%}
      <a href="{{ routes.root_url }}" class="header__heading-link link link--text focus-inset">
        {%- if settings.logo != blank -%}
          <div class="header__heading-logo-wrapper">
            {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
            {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
            {% capture sizes %}(max-width: {{ settings.logo_width | times: 2 }}px) 50vw, {{ settings.logo_width }}px{% endcapture %}
            {% capture widths %}{{ settings.logo_width }}, {{ settings.logo_width | times: 1.5 | round }}, {{ settings.logo_width | times: 2 }}{% endcapture %}
            {{
              settings.logo
              | image_url: width: 600
              | image_tag:
                class: 'header__heading-logo motion-reduce',
                widths: widths,
                height: logo_height,
                width: settings.logo_width,
                alt: logo_alt,
                sizes: sizes,
                preload: true
            }}

            {%- comment -%} ===== PHASE 2: Transparent logo (alternate logo for transparent header) ===== {%- endcomment -%}
            {%- if hp_transparent_active and section.settings.hp_transparent_logo != blank -%}
              {%- assign hp_t_logo = section.settings.hp_transparent_logo -%}
              {%- assign hp_t_logo_alt = hp_t_logo.alt | default: shop.name | escape -%}
              {%- assign hp_t_logo_height = settings.logo_width | divided_by: hp_t_logo.aspect_ratio -%}
              <img
                src="{{ hp_t_logo | image_url: width: 600 }}"
                srcset="{{ hp_t_logo | image_url: width: settings.logo_width }} {{ settings.logo_width }}w, {{ hp_t_logo | image_url: width: settings.logo_width | times: 2 }} {{ settings.logo_width | times: 2 }}w"
                sizes="{{ settings.logo_width }}px"
                width="{{ settings.logo_width }}"
                height="{{ hp_t_logo_height }}"
                alt="{{ hp_t_logo_alt }}"
                class="header__heading-logo header__heading-logo--transparent motion-reduce"
                loading="eager"
              >
            {%- endif -%}

            {%- comment -%} ===== PHASE 2: Sticky logo (alternate logo when scrolled/sticky) ===== {%- endcomment -%}
            {%- if section.settings.hp_enable_premium and section.settings.hp_sticky_logo != blank -%}
              {%- assign hp_s_logo = section.settings.hp_sticky_logo -%}
              {%- assign hp_s_logo_alt = hp_s_logo.alt | default: shop.name | escape -%}
              {%- assign hp_s_logo_height = settings.logo_width | divided_by: hp_s_logo.aspect_ratio -%}
              <img
                src="{{ hp_s_logo | image_url: width: 600 }}"
                srcset="{{ hp_s_logo | image_url: width: settings.logo_width }} {{ settings.logo_width }}w, {{ hp_s_logo | image_url: width: settings.logo_width | times: 2 }} {{ settings.logo_width | times: 2 }}w"
                sizes="{{ settings.logo_width }}px"
                width="{{ settings.logo_width }}"
                height="{{ hp_s_logo_height }}"
                alt="{{ hp_s_logo_alt }}"
                class="header__heading-logo header__heading-logo--sticky motion-reduce"
                loading="lazy"
              >
            {%- endif -%}
          </div>
        {%- else -%}
          <span class="h2">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      {%- if request.page_type == 'index' -%}
        </h1>
      {%- endif -%}
    {%- endif -%}

    {%- liquid
      if section.settings.menu != blank
        if section.settings.menu_type_desktop == 'dropdown'
          render 'header-dropdown-menu'
        elsif section.settings.menu_type_desktop != 'drawer'
          render 'header-mega-menu'
        endif
      endif
    %}

    {%- if section.settings.logo_position == 'middle-center' -%}
      {%- if request.page_type == 'index' -%}
        <h1 class="header__heading">
      {%- endif -%}
      <a href="{{ routes.root_url }}" class="header__heading-link link link--text focus-inset">
        {%- if settings.logo != blank -%}
          <div class="header__heading-logo-wrapper">
            {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
            {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
            {% capture sizes %}(min-width: 750px) {{ settings.logo_width }}px, 50vw{% endcapture %}
            {% capture widths %}{{ settings.logo_width }}, {{ settings.logo_width | times: 1.5 | round }}, {{ settings.logo_width | times: 2 }}{% endcapture %}
            {{
              settings.logo
              | image_url: width: 600
              | image_tag:
                class: 'header__heading-logo',
                widths: widths,
                height: logo_height,
                width: settings.logo_width,
                alt: logo_alt,
                sizes: sizes,
                preload: true
            }}

            {%- comment -%} ===== PHASE 2: Transparent logo (middle-center variant) ===== {%- endcomment -%}
            {%- if hp_transparent_active and section.settings.hp_transparent_logo != blank -%}
              {%- assign hp_t_logo = section.settings.hp_transparent_logo -%}
              {%- assign hp_t_logo_alt = hp_t_logo.alt | default: shop.name | escape -%}
              {%- assign hp_t_logo_height = settings.logo_width | divided_by: hp_t_logo.aspect_ratio -%}
              <img
                src="{{ hp_t_logo | image_url: width: 600 }}"
                srcset="{{ hp_t_logo | image_url: width: settings.logo_width }} {{ settings.logo_width }}w, {{ hp_t_logo | image_url: width: settings.logo_width | times: 2 }} {{ settings.logo_width | times: 2 }}w"
                sizes="(min-width: 750px) {{ settings.logo_width }}px, 50vw"
                width="{{ settings.logo_width }}"
                height="{{ hp_t_logo_height }}"
                alt="{{ hp_t_logo_alt }}"
                class="header__heading-logo header__heading-logo--transparent"
                loading="eager"
              >
            {%- endif -%}

            {%- comment -%} ===== PHASE 2: Sticky logo (middle-center variant) ===== {%- endcomment -%}
            {%- if section.settings.hp_enable_premium and section.settings.hp_sticky_logo != blank -%}
              {%- assign hp_s_logo = section.settings.hp_sticky_logo -%}
              {%- assign hp_s_logo_alt = hp_s_logo.alt | default: shop.name | escape -%}
              {%- assign hp_s_logo_height = settings.logo_width | divided_by: hp_s_logo.aspect_ratio -%}
              <img
                src="{{ hp_s_logo | image_url: width: 600 }}"
                srcset="{{ hp_s_logo | image_url: width: settings.logo_width }} {{ settings.logo_width }}w, {{ hp_s_logo | image_url: width: settings.logo_width | times: 2 }} {{ settings.logo_width | times: 2 }}w"
                sizes="(min-width: 750px) {{ settings.logo_width }}px, 50vw"
                width="{{ settings.logo_width }}"
                height="{{ hp_s_logo_height }}"
                alt="{{ hp_s_logo_alt }}"
                class="header__heading-logo header__heading-logo--sticky"
                loading="lazy"
              >
            {%- endif -%}
          </div>
        {%- else -%}
          <span class="h2">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      {%- if request.page_type == 'index' -%}
        </h1>
      {%- endif -%}
    {%- endif -%}

    <div class="header__icons{% if section.settings.enable_country_selector or section.settings.enable_language_selector %} header__icons--localization header-localization{% endif %}">
      <div class="desktop-localization-wrapper">
        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
          <localization-form class="small-hide medium-hide" data-prevent-hide>
            {%- form 'localization', id: 'HeaderCountryForm', class: 'localization-form' -%}
              <div>
                <h2 class="visually-hidden" id="HeaderCountryLabel">{{ 'localization.country_label' | t }}</h2>
                {%- render 'country-localization', localPosition: 'HeaderCountry' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {% endif %}

        {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
          <localization-form class="small-hide medium-hide" data-prevent-hide>
            {%- form 'localization', id: 'HeaderLanguageForm', class: 'localization-form' -%}
              <div>
                <h2 class="visually-hidden" id="HeaderLanguageLabel">{{ 'localization.language_label' | t }}</h2>
                {%- render 'language-localization', localPosition: 'HeaderLanguage' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}
      </div>
      {%- comment -%} ===== PHASE 4: Inline search bar OR default Dawn search modal ===== {%- endcomment -%}
      {%- if section.settings.hp_enable_premium and section.settings.hp_show_inline_search -%}
        <form
          action="{{ routes.search_url }}"
          method="get"
          role="search"
          class="hp-inline-search small-hide"
        >
          <label for="HP-InlineSearch-{{ section.id }}" class="visually-hidden">
            {{ 'general.search.search' | t }}
          </label>
          <input
            type="search"
            id="HP-InlineSearch-{{ section.id }}"
            name="q"
            value="{{ search.terms | escape }}"
            placeholder="{{ section.settings.hp_search_placeholder | default: 'Search products...' | escape }}"
            class="hp-inline-search__input"
            autocomplete="off"
          >
          <input type="hidden" name="options[prefix]" value="last">
          <button type="submit" class="hp-inline-search__submit" aria-label="{{ 'general.search.search' | t }}">
            <span class="svg-wrapper">{{ 'icon-search.svg' | inline_asset_content }}</span>
          </button>
        </form>
        {%- comment -%} Mobile still uses Dawn's modal {%- endcomment -%}
        <div class="medium-hide large-up-hide">{% render 'header-search', input_id: 'Search-In-Modal' %}</div>
      {%- else -%}
        {% render 'header-search', input_id: 'Search-In-Modal' %}
      {%- endif -%}

      {%- if shop.customer_accounts_enabled -%}
        <a
          href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
          class="header__icon header__icon--account link focus-inset{% if section.settings.menu != blank %} small-hide{% endif %}"
          rel="nofollow"
        >
          {%- if section.settings.enable_customer_avatar -%}
            <account-icon>
              {%- if customer and customer.has_avatar? -%}
                {{ customer | avatar }}
              {%- else -%}
                <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
              {%- endif -%}
            </account-icon>
          {%- else -%}
            <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
          {%- endif -%}
          <span class="visually-hidden">
            {%- liquid
              if customer
                echo 'customer.account_fallback' | t
              else
                echo 'customer.log_in' | t
              endif
            -%}
          </span>
        </a>
      {%- endif -%}

      {%- comment -%} ===== PHASE 4: Wishlist icon (optional) ===== {%- endcomment -%}
      {%- if section.settings.hp_enable_premium and section.settings.hp_show_wishlist and section.settings.hp_wishlist_url != blank -%}
        <a
          href="{{ section.settings.hp_wishlist_url | default: '#' }}"
          class="header__icon header__icon--wishlist hp-icon-wishlist link focus-inset"
          aria-label="Wishlist"
        >
          <span class="svg-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
            </svg>
          </span>
          <span class="visually-hidden">Wishlist</span>
        </a>
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            {% render block %}
        {%- endcase -%}
      {%- endfor -%}

      <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart link focus-inset" id="cart-icon-bubble">
        {% if cart == empty %}
          <span class="svg-wrapper">{{ 'icon-cart-empty.svg' | inline_asset_content }}</span>
        {% else %}
          <span class="svg-wrapper">{{ 'icon-cart.svg' | inline_asset_content }}</span>
        {% endif %}
        <span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
        {%- if cart != empty -%}
          <div class="cart-count-bubble">
            {%- if cart.item_count < 100 -%}
              <span aria-hidden="true">{{ cart.item_count }}</span>
            {%- endif -%}
