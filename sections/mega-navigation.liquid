{% comment %}
  ============================================================
  MEGA NAVIGATION SECTION
  Style:
    - Desktop : Symmetry + thejacketmaker.com
                (full-width flyout, hover trigger, multi-column,
                 featured promo card)
    - Mobile  : Prada-style full-screen drawer
                (large bold typography, slide-in, accordion)
  Architecture:
    - Independent section (theme editor: add/remove/reorder).
    - Self-contained: CSS + JS in /assets, schema below.
    - Does not modify Dawn header.liquid; complements it.
  ============================================================
{% endcomment %}

{% if section.settings.mn_enable %}
  {{ 'mega-navigation.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'mega-navigation.js' | asset_url }}" defer="defer"></script>

  {%- liquid
    if section.settings.mn_border_bottom
      assign mn_border_width = '1px'
    else
      assign mn_border_width = '0px'
    endif

    if section.settings.mn_sticky
      assign mn_sticky_attr = 'true'
    else
      assign mn_sticky_attr = 'false'
    endif

    assign nav_heading_color = section.settings.mn_dropdown_heading_color
    assign nav_text_color = section.settings.mn_dropdown_text_color
    assign nav_badge_new = section.settings.mn_badge_new_color
    assign nav_badge_sale = section.settings.mn_badge_sale_color
    assign nav_badge_hot = section.settings.mn_badge_hot_color
  -%}

  {%- style -%}
    #shopify-section-{{ section.id }} .mega-navigation-section {
      --mn-bg-color: {{ section.settings.mn_bg_color }};
      --mn-text-color: {{ section.settings.mn_text_color }};
      --mn-font-size: {{ section.settings.mn_font_size }}px;
      --mn-font-weight: {{ section.settings.mn_font_weight }};
      --mn-letter-spacing: {{ section.settings.mn_letter_spacing }}px;
      --mn-text-transform: {{ section.settings.mn_text_transform }};
      --mn-hover-color: {{ section.settings.mn_hover_color }};
      --mn-hover-underline-thickness: {{ section.settings.mn_hover_underline_thickness }}px;
      --mn-sticky-bg: {{ section.settings.mn_sticky_bg }};
      --mn-border-color: {{ section.settings.mn_border_color }};
      --mn-dropdown-bg: {{ section.settings.mn_dropdown_bg }};
      --mn-dropdown-text-color: {{ section.settings.mn_dropdown_text_color }};
      --mn-dropdown-heading-color: {{ section.settings.mn_dropdown_heading_color }};
      --mn-dropdown-duration: {{ section.settings.mn_dropdown_duration }}ms;
      --mn-badge-new-color: {{ section.settings.mn_badge_new_color }};
      --mn-badge-sale-color: {{ section.settings.mn_badge_sale_color }};
      --mn-badge-hot-color: {{ section.settings.mn_badge_hot_color }};
      --mn-mobile-font-size: {{ section.settings.mn_mobile_font_size }}px;
      --mn-mobile-padding: {{ section.settings.mn_mobile_padding }}px;
      --mn-section-padding-top: {{ section.settings.mn_section_padding_top }}px;
      --mn-section-padding-bottom: {{ section.settings.mn_section_padding_bottom }}px;
      --mn-border-bottom-width: {{ mn_border_width }};
    }
  {%- endstyle -%}

  <div
    id="section-{{ section.id }}"
    class="mega-navigation-section"
    role="region"
    aria-label="Mega navigation"
    data-mn-hover-animation="{{ section.settings.mn_hover_animation }}"
    data-mn-dropdown-animation="{{ section.settings.mn_dropdown_animation }}"
    data-mn-sticky="{{ mn_sticky_attr }}"
    data-mn-mobile-accordion-icon="{{ section.settings.mn_mobile_accordion_icon }}"
    data-mn-mobile-drawer-position="{{ section.settings.mn_mobile_drawer_position }}"
  >
    <nav class="mega-nav-bar" aria-label="Primary">
      <button
        type="button"
        class="mega-nav-hamburger"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="MegaNavDrawer-{{ section.id }}"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>

      <ul class="mega-nav-menu">
        {%- for block in section.blocks -%}
          {%- if block.type == 'menu_item' -%}

            {%- liquid
              assign col1_handle = block.settings.mn_col1_linklist
              assign col2_handle = block.settings.mn_col2_linklist
              assign col3_handle = block.settings.mn_col3_linklist
              assign col4_handle = block.settings.mn_col4_linklist
              assign col5_handle = block.settings.mn_col5_linklist
              assign col6_handle = block.settings.mn_col6_linklist

              assign col1_title = block.settings.mn_col1_title
              assign col2_title = block.settings.mn_col2_title
              assign col3_title = block.settings.mn_col3_title
              assign col4_title = block.settings.mn_col4_title
              assign col5_title = block.settings.mn_col5_title
              assign col6_title = block.settings.mn_col6_title

              assign has_columns = false
              if col1_handle != blank
                assign has_columns = true
              elsif col2_handle != blank
                assign has_columns = true
              elsif col3_handle != blank
                assign has_columns = true
              elsif col4_handle != blank
                assign has_columns = true
              elsif col5_handle != blank
                assign has_columns = true
              elsif col6_handle != blank
                assign has_columns = true
              endif

              assign has_promo = false
              if block.settings.mn_show_promo and block.settings.mn_promo_image != blank
                assign has_promo = true
              endif

              assign has_dropdown = false
              if has_columns or has_promo
                assign has_dropdown = true
              endif

              assign menu_link_url = block.settings.menu_url
              if menu_link_url == blank
                assign menu_link_url = '#'
              endif
            -%}

            <li class="mega-nav-item" data-block-id="{{ block.id }}" {{ block.shopify_attributes }}>
              <a
                href="{{ menu_link_url }}"
                class="mega-nav-link"
                {%- if block.settings.mn_use_custom_color -%}
                  data-custom-color="true"
                  style="--mn-item-color: {{ block.settings.mn_item_color }}; --mn-item-hover-color: {{ block.settings.mn_item_hover_color }}; color: {{ block.settings.mn_item_color }};"
                {%- endif -%}
              >
                {{- block.settings.menu_link -}}
                {%- case block.settings.mn_item_badge -%}
                  {%- when 'new' -%}
                    <span class="mega-nav-item-badge mega-nav-item-badge--new">NEW</span>
                  {%- when 'sale' -%}
                    <span class="mega-nav-item-badge mega-nav-item-badge--sale">SALE</span>
                  {%- when 'hot' -%}
                    <span class="mega-nav-item-badge mega-nav-item-badge--hot">HOT</span>
                {%- endcase -%}
              </a>

              {%- if has_dropdown -%}
                {%- assign dropdown_classes = 'mega-nav-dropdown' -%}
                {%- if section.settings.mn_dropdown_shadow -%}
                  {%- assign dropdown_classes = dropdown_classes | append: ' has-shadow' -%}
                {%- endif -%}
                {%- if section.settings.mn_dropdown_border -%}
                  {%- assign dropdown_classes = dropdown_classes | append: ' has-border' -%}
                {%- endif -%}

                <div class="{{ dropdown_classes }}">
                  <div class="mega-nav-dropdown__inner">
                    {%- if has_columns -%}
                      <div class="mega-nav-dropdown__columns" data-columns="{{ block.settings.mn_columns }}">
                        {%- if col1_handle != blank -%}
                          {%- render 'mega-nav-column',
                            column_title: col1_title,
                            linklist_handle: col1_handle,
                            heading_color: nav_heading_color,
                            text_color: nav_text_color,
                            badge_new_color: nav_badge_new,
                            badge_sale_color: nav_badge_sale,
                            badge_hot_color: nav_badge_hot
                          -%}
                        {%- endif -%}
                        {%- if col2_handle != blank -%}
                          {%- render 'mega-nav-column',
                            column_title: col2_title,
                            linklist_handle: col2_handle,
                            heading_color: nav_heading_color,
                            text_color: nav_text_color,
                            badge_new_color: nav_badge_new,
                            badge_sale_color: nav_badge_sale,
                            badge_hot_color: nav_badge_hot
                          -%}
                        {%- endif -%}
                        {%- if col3_handle != blank -%}
                          {%- render 'mega-nav-column',
                            column_title: col3_title,
                            linklist_handle: col3_handle,
                            heading_color: nav_heading_color,
                            text_color: nav_text_color,
                            badge_new_color: nav_badge_new,
                            badge_sale_color: nav_badge_sale,
                            badge_hot_color: nav_badge_hot
                          -%}
                        {%- endif -%}
                        {%- if col4_handle != blank -%}
                          {%- render 'mega-nav-column',
                            column_title: col4_title,
                            linklist_handle: col4_handle,
                            heading_color: nav_heading_color,
                            text_color: nav_text_color,
                            badge_new_color: nav_badge_new,
                            badge_sale_color: nav_badge_sale,
                            badge_hot_color: nav_badge_hot
                          -%}
                        {%- endif -%}
                        {%- if col5_handle != blank -%}
                          {%- render 'mega-nav-column',
                            column_title: col5_title,
                            linklist_handle: col5_handle,
                            heading_color: nav_heading_color,
                            text_color: nav_text_color,
                            badge_new_color: nav_badge_new,
                            badge_sale_color: nav_badge_sale,
                            badge_hot_color: nav_badge_hot
                          -%}
                        {%- endif -%}
                        {%- if col6_handle != blank -%}
                          {%- render 'mega-nav-column',
                            column_title: col6_title,
                            linklist_handle: col6_handle,
                            heading_color: nav_heading_color,
                            text_color: nav_text_color,
                            badge_new_color: nav_badge_new,
                            badge_sale_color: nav_badge_sale,
                            badge_hot_color: nav_badge_hot
                          -%}
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                    {%- if has_promo -%}
                      {%- assign promo_img_url = block.settings.mn_promo_image | image_url: width: 560 -%}
                      {%- assign promo_img_alt = block.settings.mn_promo_image.alt | default: block.settings.mn_promo_heading -%}
                      {%- render 'mega-nav-promo',
                        image: promo_img_url,
                        image_alt: promo_img_alt,
                        heading: block.settings.mn_promo_heading,
                        subheading: block.settings.promo_subheading,
                        button_text: block.settings.promo_button_text,
                        button_url: block.settings.promo_button_url
                      -%}
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </nav>

    {%- comment -%} ===== Mobile drawer (Prada style) ===== {%- endcomment -%}
    <div class="mega-nav-drawer-overlay" aria-hidden="true"></div>
    <div
      id="MegaNavDrawer-{{ section.id }}"
      class="mega-nav-drawer"
      data-position="{{ section.settings.mn_mobile_drawer_position }}"
      role="dialog"
      aria-modal="true"
      aria-label="Mobile menu"
    >
      <div class="mega-nav-drawer__header">
        <button
          type="button"
          class="mega-nav-drawer__close"
          aria-label="Close menu"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>

      <ul class="mega-nav-mobile-menu">
        {%- for block in section.blocks -%}
          {%- if block.type == 'menu_item' -%}

            {%- liquid
              assign m_col1_handle = block.settings.mn_col1_linklist
              assign m_col2_handle = block.settings.mn_col2_linklist
              assign m_col3_handle = block.settings.mn_col3_linklist
              assign m_col4_handle = block.settings.mn_col4_linklist
              assign m_col5_handle = block.settings.mn_col5_linklist
              assign m_col6_handle = block.settings.mn_col6_linklist

              assign m_col1_title = block.settings.mn_col1_title
              assign m_col2_title = block.settings.mn_col2_title
              assign m_col3_title = block.settings.mn_col3_title
              assign m_col4_title = block.settings.mn_col4_title
              assign m_col5_title = block.settings.mn_col5_title
              assign m_col6_title = block.settings.mn_col6_title

              assign has_submenu = false
              if m_col1_handle != blank
                assign has_submenu = true
              elsif m_col2_handle != blank
                assign has_submenu = true
              elsif m_col3_handle != blank
                assign has_submenu = true
              elsif m_col4_handle != blank
                assign has_submenu = true
              elsif m_col5_handle != blank
                assign has_submenu = true
              elsif m_col6_handle != blank
                assign has_submenu = true
              endif

              assign m_menu_url = block.settings.menu_url
              if m_menu_url == blank
                assign m_menu_url = '#'
              endif
            -%}

            <li class="mega-nav-mobile-item" {{ block.shopify_attributes }}>
              {%- if has_submenu -%}
                <button
                  type="button"
                  class="mega-nav-mobile-link"
                  data-has-submenu="true"
                  aria-expanded="false"
                >
                  <span>{{ block.settings.menu_link }}</span>
                  <span class="mega-nav-accordion-icon" aria-hidden="true">
                    {%- case section.settings.mn_mobile_accordion_icon -%}
                      {%- when 'plus' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                      {%- when 'chevron' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false"><polyline points="6 9 12 15 18 9"></polyline></svg>
                      {%- else -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    {%- endcase -%}
                  </span>
                </button>

                <div class="mega-nav-mobile-submenu">
                  <div class="mega-nav-mobile-submenu__inner">
                    {%- if m_col1_handle != blank -%}
                      {%- if m_col1_title != blank -%}
                        <h4 class="mega-nav-mobile-submenu__heading">{{ m_col1_title }}</h4>
                      {%- endif -%}
                      <ul class="mega-nav-mobile-submenu__list">
                        {%- for link in linklists[m_col1_handle].links -%}
                          <li>
                            <a href="{{ link.url }}" class="mega-nav-mobile-submenu__link">
                              {{- link.title | remove: '[NEW]' | remove: '[SALE]' | remove: '[HOT]' | strip -}}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}

                    {%- if m_col2_handle != blank -%}
                      {%- if m_col2_title != blank -%}
                        <h4 class="mega-nav-mobile-submenu__heading">{{ m_col2_title }}</h4>
                      {%- endif -%}
                      <ul class="mega-nav-mobile-submenu__list">
                        {%- for link in linklists[m_col2_handle].links -%}
                          <li>
                            <a href="{{ link.url }}" class="mega-nav-mobile-submenu__link">
                              {{- link.title | remove: '[NEW]' | remove: '[SALE]' | remove: '[HOT]' | strip -}}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}

                    {%- if m_col3_handle != blank -%}
                      {%- if m_col3_title != blank -%}
                        <h4 class="mega-nav-mobile-submenu__heading">{{ m_col3_title }}</h4>
                      {%- endif -%}
                      <ul class="mega-nav-mobile-submenu__list">
                        {%- for link in linklists[m_col3_handle].links -%}
                          <li>
                            <a href="{{ link.url }}" class="mega-nav-mobile-submenu__link">
                              {{- link.title | remove: '[NEW]' | remove: '[SALE]' | remove: '[HOT]' | strip -}}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}

                    {%- if m_col4_handle != blank -%}
                      {%- if m_col4_title != blank -%}
                        <h4 class="mega-nav-mobile-submenu__heading">{{ m_col4_title }}</h4>
                      {%- endif -%}
                      <ul class="mega-nav-mobile-submenu__list">
                        {%- for link in linklists[m_col4_handle].links -%}
                          <li>
                            <a href="{{ link.url }}" class="mega-nav-mobile-submenu__link">
                              {{- link.title | remove: '[NEW]' | remove: '[SALE]' | remove: '[HOT]' | strip -}}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}

                    {%- if m_col5_handle != blank -%}
                      {%- if m_col5_title != blank -%}
                        <h4 class="mega-nav-mobile-submenu__heading">{{ m_col5_title }}</h4>
                      {%- endif -%}
                      <ul class="mega-nav-mobile-submenu__list">
                        {%- for link in linklists[m_col5_handle].links -%}
                          <li>
                            <a href="{{ link.url }}" class="mega-nav-mobile-submenu__link">
                              {{- link.title | remove: '[NEW]' | remove: '[SALE]' | remove: '[HOT]' | strip -}}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}

                    {%- if m_col6_handle != blank -%}
                      {%- if m_col6_title != blank -%}
                        <h4 class="mega-nav-mobile-submenu__heading">{{ m_col6_title }}</h4>
                      {%- endif -%}
                      <ul class="mega-nav-mobile-submenu__list">
                        {%- for link in linklists[m_col6_handle].links -%}
                          <li>
                            <a href="{{ link.url }}" class="mega-nav-mobile-submenu__link">
                              {{- link.title | remove: '[NEW]' | remove: '[SALE]' | remove: '[HOT]' | strip -}}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}

                    {%- if block.settings.menu_url != blank -%}
                      <a
                        href="{{ block.settings.menu_url }}"
                        class="mega-nav-promo__button"
                        style="margin-top: 1.6rem;"
                      >
                        Shop all {{ block.settings.menu_link | escape }}
                      </a>
                    {%- endif -%}
                  </div>
                </div>
              {%- else -%}
                <a
                  href="{{ m_menu_url }}"
                  class="mega-nav-mobile-link"
                >
                  <span>{{ block.settings.menu_link }}</span>
                </a>
              {%- endif -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Mega Navigation",
  "class": "shopify-section-mega-navigation",
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "checkbox",
      "id": "mn_enable",
      "label": "Enable mega navigation",
      "default": true
    },
    {
      "type": "color",
      "id": "mn_bg_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "mn_text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "mn_font_size",
      "label": "Font size",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "mn_font_weight",
      "label": "Font weight",
      "options": [
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "mn_letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 5,
      "step": 1,
      "default": 1,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "mn_text_transform",
      "label": "Text transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "uppercase"
    },
    {
      "type": "header",
      "content": "Hover effects"
    },
    {
      "type": "color",
      "id": "mn_hover_color",
      "label": "Hover and underline color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "mn_hover_underline_thickness",
      "label": "Hover underline thickness",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 2,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "mn_hover_animation",
      "label": "Hover underline animation",
      "options": [
        { "value": "center-expand", "label": "Center expand" },
        { "value": "left-to-right", "label": "Left to right" },
        { "value": "fade", "label": "Fade" }
      ],
      "default": "center-expand"
    },
    {
      "type": "header",
      "content": "Sticky"
    },
    {
      "type": "checkbox",
      "id": "mn_sticky",
      "label": "Stick to top on scroll",
      "default": false
    },
    {
      "type": "color",
      "id": "mn_sticky_bg",
      "label": "Sticky background color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Border"
    },
    {
      "type": "checkbox",
      "id": "mn_border_bottom",
      "label": "Show bottom border",
      "default": true
    },
    {
      "type": "color",
      "id": "mn_border_color",
      "label": "Border color",
      "default": "#E5E5E5"
    },
    {
      "type": "header",
      "content": "Dropdown panel"
    },
    {
      "type": "color",
      "id": "mn_dropdown_bg",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "mn_dropdown_text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "mn_dropdown_heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "mn_dropdown_animation",
      "label": "Open animation",
      "options": [
        { "value": "fade", "label": "Fade" },
        { "value": "slide-down", "label": "Slide down" },
