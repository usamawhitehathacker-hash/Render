{% if section.settings.mn_enable %}
  {{ 'mega-navigation.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'mega-navigation.js' | asset_url }}" defer="defer"></script>

  {%- liquid
    if section.settings.mn_border_bottom
      assign mn_border_width = '1px'
    else
      assign mn_border_width = '0px'
    endif
  -%}

  {%- style -%}
    .mega-navigation-section {
      --mn-bg-color: {{ section.settings.mn_bg_color }};
      --mn-text-color: {{ section.settings.mn_text_color }};
      --mn-font-size: {{ section.settings.mn_font_size }}px;
      --mn-font-weight: {{ section.settings.mn_font_weight }};
      --mn-letter-spacing: {{ section.settings.mn_letter_spacing }}px;
      --mn-text-transform: {{ section.settings.mn_text_transform }};
      --mn-hover-color: {{ section.settings.mn_hover_color }};
      --mn-hover-underline-thickness: {{ section.settings.mn_hover_underline_thickness }}px;
      --mn-sticky-bg: {{ section.settings.mn_sticky_bg }};
      --mn-border-color: {{ section.settings.mn_border_color }};
      --mn-dropdown-bg: {{ section.settings.mn_dropdown_bg }};
      --mn-dropdown-text-color: {{ section.settings.mn_dropdown_text_color }};
      --mn-dropdown-heading-color: {{ section.settings.mn_dropdown_heading_color }};
      --mn-dropdown-duration: {{ section.settings.mn_dropdown_duration }}ms;
      --mn-badge-new-color: {{ section.settings.mn_badge_new_color }};
      --mn-badge-sale-color: {{ section.settings.mn_badge_sale_color }};
      --mn-badge-hot-color: {{ section.settings.mn_badge_hot_color }};
      --mn-mobile-font-size: {{ section.settings.mn_mobile_font_size }}px;
      --mn-mobile-padding: {{ section.settings.mn_mobile_padding }}px;
      --mn-section-padding-top: {{ section.settings.mn_section_padding_top }}px;
      --mn-section-padding-bottom: {{ section.settings.mn_section_padding_bottom }}px;
      --mn-border-bottom-width: {{ mn_border_width }};
    }
  {%- endstyle -%}

  {% assign nav_heading_color = section.settings.mn_dropdown_heading_color %}
  {% assign nav_text_color = section.settings.mn_dropdown_text_color %}
  {% assign nav_badge_new = section.settings.mn_badge_new_color %}
  {% assign nav_badge_sale = section.settings.mn_badge_sale_color %}
  {% assign nav_badge_hot = section.settings.mn_badge_hot_color %}

  <div
    class="mega-navigation-section"
    data-mn-hover-animation="{{ section.settings.mn_hover_animation }}"
    data-mn-dropdown-animation="{{ section.settings.mn_dropdown_animation }}"
    data-mn-sticky="{{ section.settings.mn_sticky }}"
    data-mn-mobile-accordion-icon="{{ section.settings.mn_mobile_accordion_icon }}"
    data-mn-mobile-drawer-position="{{ section.settings.mn_mobile_drawer_position }}"
  >
    <nav class="mega-nav-bar" aria-label="Mega navigation">
      <button class="mega-nav-hamburger" aria-label="Open menu" aria-expanded="false">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>

      <ul class="mega-nav-menu">
        {% for block in section.blocks %}
          {% if block.type == 'menu_item' %}
            <li class="mega-nav-item" data-block-id="{{ block.id }}" {{ block.shopify_attributes }}>
              <a
                href="{{ block.settings.menu_url }}"
                class="mega-nav-link"
                {% if block.settings.mn_use_custom_color %}
                  style="color: {{ block.settings.mn_item_color }}; --mn-hover-color: {{ block.settings.mn_item_hover_color }}; --mn-item-hover-color: {{ block.settings.mn_item_hover_color }};"
                {% endif %}
              >
                {{- block.settings.menu_link -}}
                {% if block.settings.mn_item_badge == 'new' %}
                  <span class="mega-nav-item-badge mega-nav-item-badge--new">NEW</span>
                {% elsif block.settings.mn_item_badge == 'sale' %}
                  <span class="mega-nav-item-badge mega-nav-item-badge--sale">SALE</span>
                {% elsif block.settings.mn_item_badge == 'hot' %}
                  <span class="mega-nav-item-badge mega-nav-item-badge--hot">HOT</span>
                {% endif %}
              </a>

              {% if block.settings.mn_col1_linklist != blank or block.settings.mn_col2_linklist != blank or block.settings.mn_col3_linklist != blank or block.settings.mn_col4_linklist != blank or block.settings.mn_col5_linklist != blank or block.settings.mn_col6_linklist != blank or (block.settings.mn_show_promo and block.settings.mn_promo_image != blank) %}
              <div class="mega-nav-dropdown {% if section.settings.mn_dropdown_shadow %}has-shadow{% endif %} {% if section.settings.mn_dropdown_border %}has-border{% endif %}">
                <div class="mega-nav-dropdown__inner">
                  <div class="mega-nav-dropdown__columns" data-columns="{{ block.settings.mn_columns }}">
                    {% assign col1_title = block.settings.mn_col1_title %}
                    {% assign col1_handle = block.settings.mn_col1_linklist %}
                    {% assign col2_title = block.settings.mn_col2_title %}
                    {% assign col2_handle = block.settings.mn_col2_linklist %}
                    {% assign col3_title = block.settings.mn_col3_title %}
                    {% assign col3_handle = block.settings.mn_col3_linklist %}
                    {% assign col4_title = block.settings.mn_col4_title %}
                    {% assign col4_handle = block.settings.mn_col4_linklist %}
                    {% assign col5_title = block.settings.mn_col5_title %}
                    {% assign col5_handle = block.settings.mn_col5_linklist %}
                    {% assign col6_title = block.settings.mn_col6_title %}
                    {% assign col6_handle = block.settings.mn_col6_linklist %}

                    {% if col1_handle != blank %}
                      {% render 'mega-nav-column', column_title: col1_title, linklist_handle: col1_handle, heading_color: nav_heading_color, text_color: nav_text_color, badge_new_color: nav_badge_new, badge_sale_color: nav_badge_sale, badge_hot_color: nav_badge_hot %}
                    {% endif %}
                    {% if col2_handle != blank %}
                      {% render 'mega-nav-column', column_title: col2_title, linklist_handle: col2_handle, heading_color: nav_heading_color, text_color: nav_text_color, badge_new_color: nav_badge_new, badge_sale_color: nav_badge_sale, badge_hot_color: nav_badge_hot %}
                    {% endif %}
                    {% if col3_handle != blank %}
                      {% render 'mega-nav-column', column_title: col3_title, linklist_handle: col3_handle, heading_color: nav_heading_color, text_color: nav_text_color, badge_new_color: nav_badge_new, badge_sale_color: nav_badge_sale, badge_hot_color: nav_badge_hot %}
                    {% endif %}
                    {% if col4_handle != blank %}
                      {% render 'mega-nav-column', column_title: col4_title, linklist_handle: col4_handle, heading_color: nav_heading_color, text_color: nav_text_color, badge_new_color: nav_badge_new, badge_sale_color: nav_badge_sale, badge_hot_color: nav_badge_hot %}
                    {% endif %}
                    {% if col5_handle != blank %}
                      {% render 'mega-nav-column', column_title: col5_title, linklist_handle: col5_handle, heading_color: nav_heading_color, text_color: nav_text_color, badge_new_color: nav_badge_new, badge_sale_color: nav_badge_sale, badge_hot_color: nav_badge_hot %}
                    {% endif %}
                    {% if col6_handle != blank %}
                      {% render 'mega-nav-column', column_title: col6_title, linklist_handle: col6_handle, heading_color: nav_heading_color, text_color: nav_text_color, badge_new_color: nav_badge_new, badge_sale_color: nav_badge_sale, badge_hot_color: nav_badge_hot %}
                    {% endif %}
                  </div>

                  {% if block.settings.mn_show_promo and block.settings.mn_promo_image != blank %}
                    {% assign promo_img_url = block.settings.mn_promo_image | image_url: width: 560 %}
                    {% assign promo_img_alt = block.settings.mn_promo_image.alt | default: block.settings.mn_promo_heading %}
                    {% assign promo_heading_val = block.settings.mn_promo_heading %}
                    {% assign promo_sub_val = block.settings.promo_subheading %}
                    {% assign promo_btn_text_val = block.settings.promo_button_text %}
                    {% assign promo_btn_url_val = block.settings.promo_button_url %}
                    {% render 'mega-nav-promo', image: promo_img_url, image_alt: promo_img_alt, heading: promo_heading_val, subheading: promo_sub_val, button_text: promo_btn_text_val, button_url: promo_btn_url_val %}
                  {% endif %}
                </div>
              </div>
              {% endif %}
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </nav>

    <!-- Mobile Drawer -->
    <div class="mega-nav-drawer-overlay"></div>
    <div class="mega-nav-drawer" data-position="{{ section.settings.mn_mobile_drawer_position }}">
      <div class="mega-nav-drawer__header">
        <button class="mega-nav-drawer__close" aria-label="Close menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <ul class="mega-nav-mobile-menu">
        {% for block in section.blocks %}
          {% if block.type == 'menu_item' %}
            {% assign has_submenu = false %}
            {% if block.settings.mn_col1_linklist != blank or block.settings.mn_col2_linklist != blank or block.settings.mn_col3_linklist != blank or block.settings.mn_col4_linklist != blank or block.settings.mn_col5_linklist != blank or block.settings.mn_col6_linklist != blank %}
              {% assign has_submenu = true %}
            {% endif %}

            <li class="mega-nav-mobile-item">
              {% if has_submenu %}
                <button class="mega-nav-mobile-link" data-has-submenu="true" aria-expanded="false">
                  <span>{{ block.settings.menu_link }}</span>
                  <span class="mega-nav-accordion-icon">
                    {% if section.settings.mn_mobile_accordion_icon == 'plus' %}
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    {% elsif section.settings.mn_mobile_accordion_icon == 'chevron' %}
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    {% elsif section.settings.mn_mobile_accordion_icon == 'arrow' %}
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline></svg>
                    {% endif %}
                  </span>
                </button>
                <div class="mega-nav-mobile-submenu">
                  {% if block.settings.mn_col1_linklist != blank %}
                    {% if block.settings.mn_col1_title != blank %}
                      <h4 class="mega-nav-mobile-submenu__heading">{{ block.settings.mn_col1_title }}</h4>
                    {% endif %}
                    {% assign mobile_links_1 = linklists[block.settings.mn_col1_linklist].links %}
                    <ul class="mega-nav-mobile-submenu__list">
                      {% for link in mobile_links_1 %}
                        <li><a href="{{ link.url }}" class="mega-nav-mobile-submenu__link">{{ link.title }}</a></li>
                      {% endfor %}
                    </ul>
                  {% endif %}
                  {% if block.settings.mn_col2_linklist != blank %}
                    {% if block.settings.mn_col2_title != blank %}
                      <h4 class="mega-nav-mobile-submenu__heading">{{ block.settings.mn_col2_title }}</h4>
                    {% endif %}
                    {% assign mobile_links_2 = linklists[block.settings.mn_col2_linklist].links %}
                    <ul class="mega-nav-mobile-submenu__list">
                      {% for link in mobile_links_2 %}
                        <li><a href="{{ link.url }}" class="mega-nav-mobile-submenu__link">{{ link.title }}</a></li>
                      {% endfor %}
                    </ul>
                  {% endif %}
                  {% if block.settings.mn_col3_linklist != blank %}
                    {% if block.settings.mn_col3_title != blank %}
                      <h4 class="mega-nav-mobile-submenu__heading">{{ block.settings.mn_col3_title }}</h4>
                    {% endif %}
                    {% assign mobile_links_3 = linklists[block.settings.mn_col3_linklist].links %}
                    <ul class="mega-nav-mobile-submenu__list">
                      {% for link in mobile_links_3 %}
                        <li><a href="{{ link.url }}" class="mega-nav-mobile-submenu__link">{{ link.title }}</a></li>
                      {% endfor %}
                    </ul>
                  {% endif %}
                  {% if block.settings.mn_col4_linklist != blank %}
                    {% if block.settings.mn_col4_title != blank %}
                      <h4 class="mega-nav-mobile-submenu__heading">{{ block.settings.mn_col4_title }}</h4>
                    {% endif %}
                    {% assign mobile_links_4 = linklists[block.settings.mn_col4_linklist].links %}
                    <ul class="mega-nav-mobile-submenu__list">
                      {% for link in mobile_links_4 %}
                        <li><a href="{{ link.url }}" class="mega-nav-mobile-submenu__link">{{ link.title }}</a></li>
                      {% endfor %}
                    </ul>
                  {% endif %}
                  {% if block.settings.mn_col5_linklist != blank %}
                    {% if block.settings.mn_col5_title != blank %}
                      <h4 class="mega-nav-mobile-submenu__heading">{{ block.settings.mn_col5_title }}</h4>
                    {% endif %}
                    {% assign mobile_links_5 = linklists[block.settings.mn_col5_linklist].links %}
                    <ul class="mega-nav-mobile-submenu__list">
                      {% for link in mobile_links_5 %}
                        <li><a href="{{ link.url }}" class="mega-nav-mobile-submenu__link">{{ link.title }}</a></li>
                      {% endfor %}
                    </ul>
                  {% endif %}
                  {% if block.settings.mn_col6_linklist != blank %}
                    {% if block.settings.mn_col6_title != blank %}
                      <h4 class="mega-nav-mobile-submenu__heading">{{ block.settings.mn_col6_title }}</h4>
                    {% endif %}
                    {% assign mobile_links_6 = linklists[block.settings.mn_col6_linklist].links %}
                    <ul class="mega-nav-mobile-submenu__list">
                      {% for link in mobile_links_6 %}
                        <li><a href="{{ link.url }}" class="mega-nav-mobile-submenu__link">{{ link.title }}</a></li>
                      {% endfor %}
                    </ul>
                  {% endif %}
                </div>
              {% else %}
                <a href="{{ block.settings.menu_url }}" class="mega-nav-mobile-link">
                  <span>{{ block.settings.menu_link }}</span>
                </a>
              {% endif %}
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Mega Navigation",
  "settings": [
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "checkbox",
      "id": "mn_enable",
      "label": "Enable mega navigation",
      "default": true
    },
    {
      "type": "color",
      "id": "mn_bg_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "mn_text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "mn_font_size",
      "label": "Font size",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "mn_font_weight",
      "label": "Font weight",
      "options": [
        { "value": "400", "label": "Normal (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "mn_letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 5,
      "step": 1,
      "default": 1,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "mn_text_transform",
      "label": "Text transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "uppercase"
    },
    {
      "type": "header",
      "content": "Hover Effects"
    },
    {
      "type": "color",
      "id": "mn_hover_color",
      "label": "Hover and underline color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "mn_hover_underline_thickness",
      "label": "Hover underline thickness",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 2,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "mn_hover_animation",
      "label": "Hover underline animation",
      "options": [
        { "value": "center-expand", "label": "Center expand" },
        { "value": "left-to-right", "label": "Left to right" },
        { "value": "fade", "label": "Fade" }
      ],
      "default": "center-expand"
    },
    {
      "type": "header",
      "content": "Sticky Navigation"
    },
    {
      "type": "checkbox",
      "id": "mn_sticky",
      "label": "Enable sticky navigation",
      "default": false
    },
    {
      "type": "color",
      "id": "mn_sticky_bg",
      "label": "Sticky background color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Border"
    },
    {
      "type": "checkbox",
      "id": "mn_border_bottom",
      "label": "Show bottom border",
      "default": true
    },
    {
      "type": "color",
      "id": "mn_border_color",
      "label": "Border color",
      "default": "#E5E5E5"
    },
    {
      "type": "header",
      "content": "Dropdown Panel"
    },
    {
      "type": "color",
      "id": "mn_dropdown_bg",
      "label": "Dropdown background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "mn_dropdown_text_color",
      "label": "Dropdown text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "mn_dropdown_heading_color",
      "label": "Dropdown heading color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "mn_dropdown_animation",
      "label": "Dropdown animation",
      "options": [
        { "value": "fade", "label": "Fade" },
        { "value": "slide-down", "label": "Slide down" },
        { "value": "slide-up", "label": "Slide up" },
        { "value": "zoom", "label": "Zoom" }
      ],
      "default": "fade"
    },
    {
      "type": "range",
      "id": "mn_dropdown_duration",
      "label": "Dropdown animation duration",
      "min": 100,
      "max": 600,
      "step": 50,
      "default": 250,
      "unit": "ms"
    },
    {
      "type": "checkbox",
      "id": "mn_dropdown_shadow",
      "label": "Show dropdown shadow",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "mn_dropdown_border",
      "label": "Show dropdown border",
      "default": false
    },
    {
      "type": "header",
      "content": "Badge Colors"
    },
    {
      "type": "color",
      "id": "mn_badge_new_color",
      "label": "NEW badge color",
      "default": "#16a34a"
    },
    {
      "type": "color",
      "id": "mn_badge_sale_color",
      "label": "SALE badge color",
      "default": "#E63946"
    },
    {
      "type": "color",
      "id": "mn_badge_hot_color",
      "label": "HOT badge color",
      "default": "#ea580c"
    },
    {
      "type": "header",
      "content": "Mobile Settings"
    },
    {
      "type": "select",
      "id": "mn_mobile_drawer_position",
      "label": "Mobile drawer position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" },
        { "value": "fullscreen", "label": "Fullscreen" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "mn_mobile_font_size",
      "label": "Mobile font size",
      "min": 14,
      "max": 24,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "mn_mobile_padding",
      "label": "Mobile item padding",
      "min": 8,
      "max": 24,
      "step": 2,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "mn_mobile_accordion_icon",
      "label": "Mobile accordion icon",
      "options": [
        { "value": "plus", "label": "Plus" },
        { "value": "chevron", "label": "Chevron" },
        { "value": "arrow", "label": "Arrow" }
      ],
      "default": "plus"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "mn_section_padding_top",
      "label": "Section padding top",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "mn_section_padding_bottom",
      "label": "Section padding bottom",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "menu_item",
      "name": "Menu Item",
      "settings": [
        {
          "type": "text",
          "id": "menu_link",
          "label": "Menu item title",
          "default": "Menu Item"
        },
        {
          "type": "url",
          "id": "menu_url",
          "label": "Menu item URL"
        },
        {
          "type": "header",
          "content": "Custom Color"
        },
        {
          "type": "checkbox",
          "id": "mn_use_custom_color",
          "label": "Use custom color for this item",
          "default": false
        },
        {
          "type": "color",
          "id": "mn_item_color",
          "label": "Item text color",
          "default": "#E63946"
        },
        {
          "type": "color",
          "id": "mn_item_hover_color",
          "label": "Item hover color",
          "default": "#E63946"
        },
        {
          "type": "select",
          "id": "mn_item_badge",
          "label": "Item badge",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "new", "label": "NEW" },
            { "value": "sale", "label": "SALE" },
            { "value": "hot", "label": "HOT" }
          ],
          "default": "none"
        },
        {
          "type": "header",
          "content": "Dropdown Columns"
        },
        {
          "type": "range",
          "id": "mn_columns",
          "label": "Number of columns",
          "min": 2,
          "max": 6,
          "step": 1,
          "default": 4
        },
        {
          "type": "text",
          "id": "mn_col1_title",
          "label": "Column 1 title"
