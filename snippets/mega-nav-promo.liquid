{% comment %}
  Mega Navigation Promo
  Renders a featured promo card inside the mega dropdown.
  Style: thejacketmaker.com — image card with heading,
  subheading and outline CTA button below.

  Parameters:
    - image        (string)  Pre-built image_url string
    - image_alt    (string)
    - heading      (string)
    - subheading   (string)
    - button_text  (string)
    - button_url   (string)
{% endcomment %}

<div class="mega-nav-promo">
  {% if image != blank %}
    <a
      href="{% if button_url != blank %}{{ button_url }}{% else %}#{% endif %}"
      class="mega-nav-promo__image-wrapper"
      aria-label="{{ heading | default: image_alt | escape }}"
    >
      <img
        src="{{ image }}"
        alt="{{ image_alt | escape }}"
        loading="lazy"
        width="560"
        height="700"
        class="mega-nav-promo__image"
      >
    </a>
  {% endif %}

  <div class="mega-nav-promo__content">
    {% if heading != blank %}
      <h4 class="mega-nav-promo__heading">{{ heading }}</h4>
    {% endif %}

    {% if subheading != blank %}
      <p class="mega-nav-promo__subheading">{{ subheading }}</p>
    {% endif %}

    {% if button_text != blank and button_url != blank %}
      <a href="{{ button_url }}" class="mega-nav-promo__button">{{ button_text }}</a>
    {% endif %}
  </div>
</div>
