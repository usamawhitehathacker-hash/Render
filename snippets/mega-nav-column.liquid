{% comment %}
  Mega Navigation Column
  Renders one column of links in the mega dropdown panel.

  Parameters:
    - column_title       (string)  Optional column heading
    - linklist_handle    (string)  Handle of a Shopify linklist
    - heading_color      (string)  CSS color for heading
    - text_color         (string)  CSS color for links
    - badge_new_color    (string)  CSS color for [NEW] badge
    - badge_sale_color   (string)  CSS color for [SALE] badge
    - badge_hot_color    (string)  CSS color for [HOT] badge

  Badges are inferred from the link title:
    "Hoodies [NEW]"  -> renders NEW badge, strips the tag from the title
    "Sale Items [SALE]"  -> renders SALE badge
    "Trending [HOT]"  -> renders HOT badge
{% endcomment %}

<div class="mega-nav-column">
  {% if column_title != blank %}
    <h3 class="mega-nav-column__heading" style="color: {{ heading_color }};">{{ column_title }}</h3>
  {% endif %}

  {% if linklist_handle != blank %}
    {% assign mn_links = linklists[linklist_handle].links %}
    {% if mn_links.size > 0 %}
      <ul class="mega-nav-column__list">
        {% for link in mn_links %}
          {% assign link_title = link.title %}
          {% assign badge_type = '' %}

          {% if link_title contains '[NEW]' %}
            {% assign badge_type = 'new' %}
            {% assign link_title = link_title | remove: '[NEW]' | strip %}
          {% elsif link_title contains '[SALE]' %}
            {% assign badge_type = 'sale' %}
            {% assign link_title = link_title | remove: '[SALE]' | strip %}
          {% elsif link_title contains '[HOT]' %}
            {% assign badge_type = 'hot' %}
            {% assign link_title = link_title | remove: '[HOT]' | strip %}
          {% endif %}

          <li class="mega-nav-column__item">
            <a
              href="{{ link.url }}"
              class="mega-nav-column__link"
              style="color: {{ text_color }};"
            >
              {{- link_title -}}
              {% if badge_type == 'new' %}
                <span class="mega-nav-badge" style="background-color: {{ badge_new_color }};">NEW</span>
              {% elsif badge_type == 'sale' %}
                <span class="mega-nav-badge" style="background-color: {{ badge_sale_color }};">SALE</span>
              {% elsif badge_type == 'hot' %}
                <span class="mega-nav-badge" style="background-color: {{ badge_hot_color }};">HOT</span>
              {% endif %}
            </a>
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  {% endif %}
</div>
